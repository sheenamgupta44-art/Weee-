im.order_date,im.delivery_date,im.rn_order,im.rn_delivery,im.supply_mode,im.connection_inventory_id,im.connection_inventory_type,im.last_available_date,
CASE
WHEN im.oos_reason = 'unknown' THEN
CASE
--when im.inventory_id = 16 and im.purchase_method = 'L' and im.is_purchase = 'N' then
--'Out of scope - Clifton SKU where purchasing method is L and flag is off'
when dc_lane.calculation_tags like '%VENDOR%' and dc_lane.initial_quantity > 0 and dc_lane.quantity = 0
then 'MOQ Issue - No order submitted due to MOQ'
WHEN most_recent_po_sku_receipt_date IS NULL AND most_recent_entire_po_receiving_date IS NOT NULL
THEN 'Vendor OOS - last PO SKU not received - but other SKU received'
when most_recent_po_sku_receipt_date IS NULL AND most_recent_entire_po_receiving_date IS NULL and mr.po_creation_date is not null
then 'Vendor OOS - Entire PO Not Received'
when od.purchase_order_id is not null and mr.purchase_order_id is null and irspr.irs_pr_submission_status = 'SUCCESS' then
'Vendor OOS - Vendor deleted SKU from PO'
when most_recent_po_requested_qty < pr.qty
then 'Possible vendor shortage issue - Last PO qty less than pr qty, '
when rmp.manual_item_receipt_date is null and rmp.product_id is not null
then 'Manual PO SKU with enough lead time not received'
when mr.po_receiving_date > mr.po_est_delivery_date
then 'PO arrived late'
when sr.item_receipt_date_second is null and sr.purchase_order_id_second is not null
then 'Vendor OOS - 2nd recent PO SKU not received, not enough time to catch up'
when inv.order_quantity > 0 and mr.product_id is null then
'Vendor OOS - No PO created on order date with Order Quantity'
when im.order_date < earliest_inputted_demand_date then
'No forecasted demand during last order date'
--when (dml.date_made_live > im.order_date) then
--'SKU Made Live too recently to go through PR/PO cycle'
when irs_pr_submission_status = 'FAILED'
then 'Error in missed PR-PO conversion in last order cycle'
--WHEN irs.avg_daily_sales = 0 THEN 'unknown'
when pro.product_id is not null and pro.rec_create_time > im.order_date
then 'Promotion SKU Demand inputted after order date'
when ((irs.avg_daily_sales-irs.avg_daily_demand_forecast)/nullif(irs.avg_daily_sales,0) > 0.1)
--or
-- (irs.sellable_quantity >= irs.target_quantity and irs.sellable_quantity is not null ) or
--(la.target_quantity/2 >= inv.target_quantity) or
--zoq.order_quantity = 0 and zoq.target_quantity > 0
then 'Demand Underforecasted'
--when inv.product_id is null then 'Not in IRS, Likely Config Error'
when inv.product_id is null then 'Config Error - Not in IRS Previously'
ELSE im.oos_reason -- If the inner condition is not met, use the original oos_reason
END
ELSE im.oos_reason -- If oos_reason is not 'unknown', return the original oos_reason
END AS oos_reason
from input_metrics im
left join
most_recent_po mr on im.product_id = mr.product_id and im.inventory_id = mr.inventory_id and mr.po_creation_date = im.order_date
left join second_recent_po sr on sr.product_id = im.product_id and sr.inventory_id = im.inventory_id
left join order_date_entire_po od on im.product_id = od.product_id and im.inventory_id = od.inventory_id
left join irspr_inventory_adjusted irspr on im.product_id = irspr.product_id and im.inventory_id = irspr.facility_id_adjusted and im.order_date = irspr.order_date
left join inv_inventory_adjusted inv on im.product_Id = inv.product_id and im.inventory_id = inv.facility_id_adjusted and im.order_date = inv.snapshot_date
--left join    pr_purchase_request pr on im.product_id = pr.product_id and im.inventory_id = pr.inventory_id and im.order_date = pr.order_date and pr.vendor_id = im.vendor_id
left join most_recent_pr pr on im.product_id = pr.product_id and im.inventory_id = pr.inventory_id and im.order_date = pr.order_date and pr.vendor_id = im.vendor_id
left join fcst_sales irs on
im.product_id = irs.product_id and im.inventory_id = irs.inventory_id
left join most_recent_manual_po rmp on im.product_id = rmp.product_id and im.inventory_id = rmp.inventory_id
left join date_made_live dml on im.product_id = dml.product_id and im.inventory_id = dml.inventory_id
left join last_available_input la on im.product_id = la.product_id and im.inventory_id = la.inventory_id
left join irs_info_zero_order_qty zoq on im.product_id = zoq.product_id and im.inventory_id = zoq.inventory_id
left join inv_inventory_adjusteda inva on im.product_Id = inva.product_id and im.inventory_id = inva.facility_id_adjusted
left join promo_check pro on pro.product_id = im.product_id and pro.inventory_id = im.inventory_id
left join sandbox.facility_tag_pair_sku tg on tg.product_id = im.product_id and tg.facility_tag_pair = 'East to West' and im.inventory_id = 16
left join dwd.irs_network_product_destination_replenishment_lane dc_lane on dc_lane.product_id = im.product_id and dc_lane.destination_facility_id = im.inventory_id and
dc_lane.snapshot_date = im.order_date
