DROP TABLE IF EXISTS irs_submission;
CREATE TEMPORARY TABLE irs_submission AS (
SELECT
product_id,
facility_id,
-- Show 'failed' only if there's no 'success', or show 'success' if it's present
CASE
WHEN SUM(CASE WHEN submission_status = 'SUCCESS' THEN 1 ELSE 0 END) > 0 THEN
'success'
WHEN SUM(CASE WHEN submission_status = 'FAILED' THEN 1 ELSE 0 END) > 0 THEN
'failed'
ELSE
NULL -- Exclude 'null' statuses, which means no status at all for that group
END AS submission_status
FROM  irs_network_purchase_order_product
WHERE snapshot_date =        '2026-01-15'-1
AND submission_status IS NOT NULL -- Exclude rows where submission_status is null
GROUP BY product_id, facility_id, snapshot_date
HAVING COUNT(*) = 1 -- Ensure there's no duplication of product_id and facility_id
);


