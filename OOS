drop table if exists dc_fc_oos_reason_codes;
create temporary table dc_fc_oos_reason_codes as (
select distinct sku.*,
lai.last_available_date,
dcavl.last_available_date as dc_last_available_date,
coalesce(req.submitted_order_quantity,0) as base_fc_order_quantity_submitted ,
req.req_order_quantity as base_fc_recommended_order_quantity,
case when irs.final_planning_horizon_days >= 28 then irs.avg_daily_demand_forecast * 14
when irs.final_planning_horizon_days <= 28 then irs.avg_daily_demand_forecast * 2
end as dc_priority_1_reserve_qty,
coalesce(bb.qty,0) as dc_bin_qty, coalesce(sto.qty,0) as dc_stock_qty,
irs.sellable_quantity, irs.target_quantity,irs.order_quantity, irs.available_quantity,
irs.final_planning_horizon_days,irs.is_order_quantity_satisfied_by_primary_lane,
sa.sold_qty as sold_qty_last_available_date,df.snapshot_date as snapshot_demand_forecasted, df.date_demand_forecasted_for, df.qty_forecasted,
st.status_title,st.invoice_id,st.date_transfer_order_created as most_recent_internal_transfer_created_date,
st.original_quantity,st.receipt_quantity,st.estimated_pickup_date, st.actual_pickup_date,
st.estimated_delivery_date, st.actual_delivery_date,
req.req_order_quantity,
       '2026-01-15'-1-lai.last_available_date as days_oos,
case
when dc_priority_1_reserve_qty > irs.sellable_quantity and irs.sellable_quantity > 0
then 'Supplier to DC Issue: DC has zero transferrable inventory due to reserve quantity'
when st.actual_delivery_date > st.estimated_delivery_date and st.actual_pickup_date > st.estimated_pickup_date
then 'DC to FC Issue: Shipment late due to late pickup'
when st.actual_delivery_date > st.estimated_delivery_date and st.actual_pickup_date = st.estimated_pickup_date
then 'DC to FC Issue: shipment late due to carrier arriving late, pickup on time'
WHEN (COALESCE(sku.priority_1_sellable_qty, 0)) <= 0 or ((irs.is_order_quantity_satisfied_by_primary_lane is null or irs.is_order_quantity_satisfied_by_primary_lane = 0) and irs.order_quantity > 0)
then 'Supplier to DC Issue: DC has zero transferrable inventory'
WHEN df.qty_forecasted = 0 and lai.last_available_date > sku.priority_1_dc_order_date then 'DC to FC Issue: No forecasted demand at order date'
when pm.product_id is not null and pm.rec_create_time > sku.priority_1_dc_order_date then
'DC to FC Issue - Promotion SKU created after order date'
when sub.submission_status = 'FAILED' then 'DC to FC Issue - PR Failed'
when req.submitted_order_quantity < req.req_order_quantity then
'DC to FC Issue - recommended order quantity < submitted quantity, not enough inventory at DC'
when tr.original_quantity < tr.receipt_quantity then 'DC to FC Issue - inventory lost during shipping'
when (sa.sold_qty - df.qty_forecasted) / sa.sold_qty > 0.1 then 'DC to FC Issue - demand underforecasted at DC Order Date'
--when (sal.sold_qty - fcst.qty_forecasted) / sal.sold_qty > 0.1 then 'Supplier to DC Issue - demand underforecasted at Supplier Order Date'
--when st.product_id is null and irs.is_order_quantity_satisfied_by_primary_lane = 1 and irs.order_quantity > 0 then 'DC to FC Issue - DC backlog issue (No internal order placed in last 7 days & transferrable inventory w/ order quantity)'
else 'unknown'
END AS dc_oos_reason_code
from
sellable_dc_sku sku
left join last_available_input lai on
sku.product_id = lai.product_id and sku.inventory_id = lai.inventory_id
left join last_available_input_dc dcavl on sku.product_id = dcavl.product_id and sku.priority_1_dc_id = dcavl.inventory_id
left join sales sa on sa.product_id=sku.product_id and sa.inventory_id = sku.inventory_id
left join available_date_adjusted_df df on df.product_id = sku.product_id and df.inventory_id = sku.inventory_id
left join irs_submission sub on sku.product_id = sub.product_id and sku.inventory_id = sub.facility_id
left join shipping_transactions tr on sku.product_id = tr.product_id and sku.inventory_id = tr.inventory_id
left join shipping_transactions_past_week st on sku.product_id = st.product_id and sku.inventory_id = st.inventory_id
left join irs_qty_req_submitted req on sku.product_id = req.product_id and sku.inventory_id = req.facility_id
left join irs_qty_req_submitted reqa on sku.inventory_id = req.facility_id
left join promo_check pm on sku.product_id = pm.product_id and sku.inventory_id = pm.inventory_id
left join available_date_adjusted_df_supplier_to_dc fcst on fcst.product_id = sku.product_id and fcst.inventory_id = sku.inventory_id
left join fc_sales_sum_dc sal on sal.product_id = sku.product_id and sal.inventory_id = sku.inventory_id
left join   irs_network_product_calculation irs on sku.product_id = irs.product_id and irs.snapshot_date = sku.priority_1_dc_order_date and
CASE
WHEN irs.facility_id = 37 THEN 7
WHEN irs.facility_id = 33 THEN 16
ELSE irs.facility_id
END = sku.inventory_id
left join bin_inventory bb on sku.product_id = bb.product_id and sku.inventory_id = bb.inventory_id
left join stock_inventory sto on sku.product_id = sto.product_id and sku.inventory_id = sto.inventory_id
);

