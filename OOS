DROP TABLE IF EXISTS available_date_adjusted_df_a;
CREATE TEMPORARY TABLE available_date_adjusted_df_a AS (
WITH ranked_data AS (
SELECT
df.product_id,
ism.warehouse_number AS inventory_id,
df.snapshot_date,
sku.priority_1_dc_order_date AS order_date,
lai.last_available_date,
df.day AS date_demand_forecasted_for,
df.qty_final,
ROW_NUMBER() OVER (PARTITION BY df.product_id, ism.warehouse_number ORDER BY df.snapshot_date DESC) AS rn
FROM dwd.df_demand_forecast_daily_snapshot63 df
INNER JOIN   wms_inv_sales_mapping ism
ON df.sales_org_id = ism.sales_org_id
INNER JOIN last_available_input lai
ON lai.product_id = df.product_id
AND lai.inventory_id = ism.warehouse_number
AND lai.last_available_date = df.day
LEFT JOIN sellable_dc_sku sku
ON lai.product_id = sku.product_id
AND lai.inventory_id = sku.inventory_id
WHERE
lai.last_available_date > sku.priority_1_dc_order_date
AND df.snapshot_date < sku.priority_1_dc_order_date
)
SELECT
product_id,
inventory_id,
max(snapshot_date) AS snapshot_date, -- Get the most recent snapshot_date
max(order_date) AS order_date,
max(last_available_date) AS last_available_date,
max(date_demand_forecasted_for) AS date_demand_forecasted_for,
max(CASE WHEN rn = 1 THEN qty_final ELSE NULL END) AS qty_forecasted -- Select qty_final for the most recent snapshot
FROM ranked_data
WHERE rn = 1 -- Only pick the most recent row for each product and inventory
GROUP BY product_id, inventory_id
);

