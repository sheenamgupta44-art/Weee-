drop table if exists config_check;
create temporary table config_check as (
SELECT DISTINCT
'2026-01-15' - 1 AS snapshot_date,
ima.product_id,
ima.inventory_id,
pat.weee_buyer_name,
mp.sku_owner,
mpw.purchase_method,
mpw.primary_vendor_id AS vendor_id,
mp.storage_type,
CASE
WHEN dr.dedicated_user_id IS NULL AND dc.order_weekday IS NULL AND ir.supply_mode IS NULL
THEN 'Dedicated Relationship, Delivery Calendar, and Inventory Relation Errors'
WHEN dr.dedicated_user_id IS NULL AND dc.order_weekday IS NULL
THEN 'Dedicated Relationship and Delivery Calendar Errors'
WHEN dr.dedicated_user_id IS NULL AND ir.supply_mode IS NULL
THEN 'Dedicated Relationship and Inventory Relation Errors'
WHEN dc.order_weekday IS NULL AND ir.supply_mode IS NULL
THEN 'Delivery Calendar and Inventory Relation Errors'
WHEN dr.dedicated_user_id IS NULL
THEN 'Dedicated Relationship Error'
WHEN dc.order_weekday IS NULL
THEN 'Delivery Calendar Error'
WHEN ir.supply_mode IS NULL
THEN 'Inventory Relation Error'
ELSE 'No Issue'
END AS config_issue
FROM
input_metrics ima
left join mdse_product_warehouse mpw on
ima.product_id = mpw.product_id and ima.inventory_id =
CASE
WHEN mpw.inventory_id = 33 THEN 16
WHEN mpw.inventory_id = 37 THEN 7
ELSE mpw.inventory_id
END
LEFT JOIN
dwd.mdse_product mp
ON mpw.product_id = mp.product_id
LEFT JOIN
   sc_pr_config_dedicated_relation dr
ON mpw.primary_vendor_id = dr.vendor_id
AND mp.storage_type = dr.storage_type
AND mpw.inventory_id = dr.warehouse_id
LEFT JOIN
 sc_pr_config_delivery_calendar dc
ON mpw.primary_vendor_id = dc.vendor_id
AND mp.storage_type = dc.storage_type
AND mpw.inventory_id = dc.inventory_id
LEFT JOIN
 sc_pr_config_inventory_relation ir
ON mpw.primary_vendor_id = ir.vendor_id
AND mp.storage_type = ir.storage_type
LEFT JOIN
metrics.product_availability pat
ON mpw.product_id = pat.product_id
AND mpw.inventory_id = pat.inventory_id
AND pat.visit_day = '2026-01-15' - 1
WHERE
--mpw.purchase_status_desc = 'Live'
mp.division NOT IN ('Produce', 'Packaging Material') and
mpw.purchase_method = 'L' and
(
dr.dedicated_user_id IS NULL OR
dc.order_weekday IS NULL OR
ir.supply_mode IS NULL
)
ORDER BY
mpw.product_id, mpw.inventory_id
);

drop table if exists local_to_dc_oos_reason;
create temporary table local_to_dc_oos_reason as (
select distinct im.product_id,im.inventory_id,
im.order_date,im.delivery_date,
pr.qty as pr_qty,dml.date_made_live,
irs.avg_daily_sales,irs.avg_daily_demand_forecast,
       '2026-01-15'-1 - la.last_available_date as days_oos,
pro.rec_create_time as date_promotion_demand_inputted,pro.product_start_time as promotion_start_date, pro.product_end_time as promotion_end_date,
la.weee_buyer_name,
im.primary_vendor_id,im.primary_vendor_title,
uni.sold_dc_mapping, uni.df_dc_mapping,
case when pro.product_id is not null then 'promotion_sku' else 'non_promotion_sku' end as promotion_sku_status,irs.promo_lift_qty,
inv.order_quantity as suggested_order_date_order_quantity,inv.target_quantity as order_date_target_quantity,inv.sellable_quantity as order_date_sellable_quantity,
irspr.irs_pr_submitted_quantity as irs_pr_submitted_quantity, irspr.irs_pr_submission_status as irs_pr_submission_status,irspr.irs_pr_id as irs_pr_id,
la.order_quantity as last_available_order_quantity,la.target_quantity as last_available_target_quantity,la.sellable_quantity as last_available_sellable_quantity,
mr.purchase_order_id as most_recent_purchase_order_id,mr.po_creation_date as most_recent_po_date,mr.po_requested_qty as most_recent_po_requested_qty,
mr.po_received_qty as most_recent_po_received_qty,mr.po_est_delivery_date as most_recent_po_delivery_date, mr.po_receiving_date as most_recent_entire_po_receiving_date,mr.item_receipt_date as most_recent_po_sku_receipt_date,
rmp.purchase_order_id as most_recent_manual_purchase_order_id,manual_po_creation_date,manual_po_est_delivery_date,manual_po_receiving_date,manual_item_receipt_date,manual_last_available_date,
sr.purchase_order_id_second as second_most_recent_purchase_order_id,sr.second_po_creation_date,sr.second_est_delivery_date,sr.po_receipt_date_second,sr.item_receipt_date_second, im.last_available_date,
CASE
--when im.inventory_id = 16 and im.purchase_method = 'L' and im.is_purchase = 'N' then
--'Supplier - DC Issue: Out of scope - Clifton SKU where purchasing method is L and flag is off'
when dc_lane.calculation_tags like '%VENDOR%' and dc_lane.initial_quantity > 0 and dc_lane.quantity = 0
then 'Supplier to DC leg: MOQ Issue - No order submitted due to MOQ'
WHEN most_recent_po_sku_receipt_date IS NULL AND most_recent_entire_po_receiving_date IS NOT NULL
THEN 'Supplier to DC Issue: No Transferrable DC Inventory due to Vendor OOS - last PO SKU not received - but other SKU received'
when most_recent_po_sku_receipt_date IS NULL AND most_recent_entire_po_receiving_date IS NULL and mr.po_creation_date is not null
then 'Supplier to DC Issue: No Transferrable DC Inventory due to Vendor OOS - Entire PO Not Received'
when od.purchase_order_id is not null and mr.purchase_order_id is null and irspr.irs_pr_submission_status = 'SUCCESS' then
'Supplier to DC Issue: No Transferrable DC Inventory due to Vendor OOS - Vendor deleted SKU from PO'
when most_recent_po_requested_qty < pr.qty
then 'Supplier to DC Issue: No Transferrable DC Inventory due to Possible vendor shortage issue - Last PO qty less than pr qty, '
when rmp.manual_item_receipt_date is null and rmp.product_id is not null
then 'Supplier to DC Issue: No Transferrable DC Inventory due to Manual PO SKU with enough lead time not received'
when mr.po_receiving_date > mr.po_est_delivery_date
then 'Supplier to DC Issue: No Transferrable DC Inventory due to PO arrived late'
when sr.item_receipt_date_second is null and sr.purchase_order_id_second is not null
then 'Supplier to DC Issue: No Transferrable DC Inventory due to Vendor OOS - 2nd recent PO SKU not received, not enough time to catch up'
when im.order_date < earliest_inputted_demand_date then
'Supplier to DC leg: No Transferrable DC Inventory due to No forecasted demand during last order date'
when inv.order_quantity > 0 and mr.product_id is null then
'Supplier to DC Issue: No PO created on order date due to Vendor OOS'
--when (dml.date_made_live > im.order_date) then
--'SKU Made Live too recently to go through PR/PO cycle'
when irspr.irs_pr_submission_status = 'FAILED'
then 'Supplier to DC Issue: No Transferrable DC Inventory due to error in missed PR-PO conversion in last order cycle'
--WHEN irs.avg_daily_sales = 0 THEN 'unknown'
when pro.product_id is not null and pro.rec_create_time > im.order_date
then 'Supplier to DC Issue: No Transferrable DC Inventory due to Promotion SKU Demand inputted after order date'
when ((uni.sold_dc_mapping-uni.df_dc_mapping)/nullif(uni.sold_dc_mapping,0) > 0.1) then 'Supplier to DC Issue: DC OOS due to Demand Underforecasted'
--or
-- (irs.sellable_quantity >= irs.target_quantity and irs.sellable_quantity is not null ) or
--(la.target_quantity/2 >= inv.target_quantity) or
--zoq.order_quantity = 0 and zoq.target_quantity > 0
--then 'Supplier to DC Issue: DC OOS due to Demand Underforecasted'
when inv.product_id is null and im.order_date is not null
then 'Supplier to DC Issue: No Transferrable DC Inventory due to Config Error - Not in IRS Previously'
--when cc.config_issue != 'No Issue' and cc.config_issue is not null then 'Supplier to DC Issue: Config Error'
ELSE 'Supplier to DC Issue: No Transferrable DC Inventory - Reason Unknown' -- If oos_reason is not 'unknown', return the original oos_reason
END AS oos_reason
from input_metrics im
left join
most_recent_po mr on im.product_id = mr.product_id and im.inventory_id = mr.inventory_id and mr.po_creation_date = im.order_date
left join second_recent_po sr on sr.product_id = im.product_id and sr.inventory_id = im.inventory_id
left join order_date_entire_po od on im.product_id = od.product_id and im.inventory_id = od.inventory_id
left join irspr_inventory_adjusted irspr on im.product_id = irspr.product_id and im.inventory_id = irspr.facility_id_adjusted and im.order_date = irspr.order_date
left join inv_inventory_adjusted inv on im.product_Id = inv.product_id and im.inventory_id = inv.facility_id_adjusted and im.order_date = inv.snapshot_date
--left join    pr_purchase_request pr on im.product_id = pr.product_id and im.inventory_id = pr.inventory_id and im.order_date = pr.order_date and pr.vendor_id = im.vendor_id
left join most_recent_pr pr on im.product_id = pr.product_id and im.inventory_id = pr.inventory_id and im.order_date = pr.order_date and pr.vendor_id = im.vendor_id
left join fcst_sales irs on
im.product_id = irs.product_id and im.inventory_id = irs.inventory_id
left join most_recent_manual_po rmp on im.product_id = rmp.product_id and im.inventory_id = rmp.inventory_id
left join date_made_live dml on im.product_id = dml.product_id and im.inventory_id = dml.inventory_id
left join last_available_input la on im.product_id = la.product_id and im.inventory_id = la.inventory_id
left join irs_info_zero_order_qty zoq on im.product_id = zoq.product_id and im.inventory_id = zoq.inventory_id
left join inv_inventory_adjusteda inva on im.product_Id = inva.product_id and im.inventory_id = inva.facility_id_adjusted
left join promo_check pro on pro.product_id = im.product_id and pro.inventory_id = im.inventory_id
left join config_check cc on cc.product_id and im.product_id and cc.inventory_id = im.inventory_id
LEFT JOIN mdse_product_warehouse mpw
ON mpw.product_id = im.product_id
AND CASE
WHEN mpw.inventory_id = 37 THEN 7
WHEN mpw.inventory_id = 33 THEN 16
ELSE mpw.inventory_id
END = im.inventory_id
left join unique_dc_fcst_sales uni on im.product_id = uni.product_id and im.inventory_id = uni.priority_1_dc_id
left join dwd.irs_network_product_destination_replenishment_lane dc_lane on dc_lane.product_id = im.product_id and dc_lane.destination_facility_id = im.inventory_id and dc_lane.snapshot_date = im.order_date
);




