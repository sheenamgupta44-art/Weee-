END AS priority_1_dc_id,
CASE
WHEN priority = 1 AND facility_level_tag_pair = 0 THEN review_1_date
WHEN priority = 1 AND facility_level_tag_pair = 1 AND sku_level_tag_pair IS NOT NULL THEN review_1_date
WHEN priority = 2 AND facility_level_tag_pair = 0 THEN review_1_date
WHEN priority = 2 AND facility_level_tag_pair = 1 AND sku_level_tag_pair IS NOT NULL THEN review_1_date
WHEN priority = 3 AND facility_level_tag_pair = 0 THEN review_1_date
WHEN priority = 3 AND facility_level_tag_pair = 1 AND sku_level_tag_pair IS NOT NULL THEN review_1_date
