DROP TABLE IF EXISTS product_price;
CREATE TEMPORARY TABLE product_price AS (
WITH ranked_prices AS (
select
pa.product_id,
pa.inventory_id,
pa.visit_day,
pa.storage_type,
pa.primary_vendor,
pa.primary_vendor_title,
pa.purchase_method,
pri.price,
ROW_NUMBER() OVER (PARTITION BY pa.product_id, pri.sales_org_id ORDER BY pri.id DESC) AS row_num
FROM
metrics.product_availability pa
LEFT JOIN
dwd.mdse_product_price pri
ON pa.product_id = pri.product_id
AND pa.sales_org_id = pri.sales_org_id
WHERE
pa.visit_day =        '2026-01-15'-1
)
SELECT
product_id,
inventory_id,
visit_day,
storage_type,
primary_vendor,
primary_vendor_title,
purchase_method,
AVG(price) AS price
FROM
ranked_prices
WHERE
row_num = 1
GROUP BY
product_id, inventory_id, visit_day, storage_type, primary_vendor, primary_vendor_title, purchase_method
);

DROP TABLE IF EXISTS last_available_input;
CREATE TEMPORARY TABLE last_available_input AS (
WITH last_available AS (
select
--CASE
--WHEN inventory_id = 16 THEN 33
--WHEN inventory_id = 7 THEN 37
--ELSE inventory_id
--END AS
inventory_id,
a.product_id,
MAX(a.visit_day) AS last_available_date,
MAX(a.product_sale_status_title) as product_sale_status_title,
MAX(irs.target_quantity) as target_quantity,
max(irs.sellable_quantity) as sellable_quantity,
max(irs.order_quantity) as order_quantity,
MAX(irs.avg_daily_sales) as avg_daily_sales,
MAX(irs.avg_daily_demand_forecast) as avg_daily_demand_forecast
FROM metrics.product_availability a
LEFT JOIN dwd.mdse_product b ON a.product_id = b.product_id
LEFT JOIN   wms_inv_sales_mapping c ON a.sales_org_id = c.sales_org_id AND b.storage_type = c.storage_type
left join   irs_network_product_calculation irs on a.product_id = irs.product_id and a.inventory_id = irs.facility_id and a.visit_day = irs.snapshot_date
WHERE a.available > 0 and a.visit_day <=        '2026-01-15'-1
GROUP BY a.inventory_id, a.product_id
)
SELECT *
FROM last_available
);


DROP TABLE IF EXISTS dc_transfer_schedule_a;
CREATE TEMPORARY TABLE dc_transfer_schedule_a AS (
WITH max_delivery_date_cte AS (
SELECT
CASE
WHEN sd.dc_id = 33 THEN 16
WHEN sd.dc_id = 37 THEN 7
ELSE sd.dc_id
END AS dc_id,
sd.dc_name,
case when sd.fc_id = 33 then 16
when sd.fc_id = 37 then 7
else sd.fc_id
end as fc_id,
sd.fc_name,
sd.storage_type,
sd.tag_pair,
sd.tag_pair_binary,
sd.priority,
sd.review_day_of_week_1,
sd.review_day_of_week_2,
sd.order_day_of_week,
sd.pickup_day_of_week,
sd.delivery_day_of_week,
sd.pickup_date_days_from_delivery,
sd.order_date_days_from_delivery,
sd.review_2_date_days_from_delivery,
sd.review_1_date_days_from_delivery,
-- Find the max delivery date from dim.calendar based on the day_of_week matching
MAX(c.cal_date) AS max_delivery_date
FROM
sandbox.dc_schedule_details_v7 sd
JOIN dim.calendar c
ON c.day_of_week = sd.delivery_day_of_week
WHERE
c.cal_date BETWEEN        '2026-01-15'-1 - 30 and        '2026-01-15'-1
GROUP BY
sd.dc_id, sd.dc_name, sd.fc_id, sd.fc_name, sd.storage_type, sd.priority,
sd.review_day_of_week_1, sd.review_day_of_week_2, sd.order_day_of_week,
sd.pickup_day_of_week, sd.delivery_day_of_week,
sd.pickup_date_days_from_delivery, sd.order_date_days_from_delivery,
sd.review_2_date_days_from_delivery, sd.review_1_date_days_from_delivery,sd.tag_pair,sd.tag_pair_binary
)

-- Step 2: Join back to get the days from the max delivery date and calculate all other dates
SELECT
mdd.dc_id,
mdd.dc_name,
mdd.fc_id,
mdd.fc_name,
mdd.storage_type,
mdd.tag_pair,
mdd.tag_pair_binary,
mdd.priority,
mdd.max_delivery_date-1 AS delivery_date,
-- Calculate the other dates by subtracting days from the max delivery date
mdd.max_delivery_date - sd.pickup_date_days_from_delivery-1 AS pickup_date,
mdd.max_delivery_date - sd.order_date_days_from_delivery-1 AS order_date,
mdd.max_delivery_date - sd.review_1_date_days_from_delivery-1 AS review_1_date,
mdd.max_delivery_date - sd.review_2_date_days_from_delivery-1 AS review_2_date

FROM
max_delivery_date_cte mdd

-- Rejoin the original table to get the day offsets
JOIN   dc_schedule_details_v7 sd
ON (
CASE
WHEN sd.dc_id = 33 THEN 16
WHEN sd.dc_id = 37 THEN 7
ELSE sd.dc_id
END
) = (
CASE
WHEN mdd.dc_id = 33 THEN 16
WHEN mdd.dc_id = 37 THEN 7
ELSE mdd.dc_id
END
)
AND (
CASE
WHEN sd.fc_id = 33 THEN 16
WHEN sd.fc_id = 37 THEN 7
ELSE sd.fc_id
END
) = (
CASE
WHEN mdd.fc_id = 33 THEN 16
WHEN mdd.fc_id = 37 THEN 7
ELSE mdd.fc_id
END
)
AND sd.storage_type = mdd.storage_type
AND sd.priority = mdd.priority
);

DROP TABLE IF EXISTS dc_transfer_schedule;
CREATE TEMPORARY TABLE dc_transfer_schedule AS (
WITH ranked_schedule AS (
SELECT
*,
ROW_NUMBER() OVER (
PARTITION BY fc_id, dc_id, storage_type, priority
ORDER BY ABS(EXTRACT(EPOCH FROM (delivery_date - ('2026-01-15' - INTERVAL '1 day')))) ASC
) AS row_num
FROM
dc_transfer_schedule_a
)
SELECT *
FROM ranked_schedule
WHERE row_num = 1
);

DROP TABLE IF EXISTS dc_sku_transfer_schedule_a;
CREATE TEMPORARY TABLE dc_sku_transfer_schedule_a AS (
WITH dc_sku_transfer_schedule_a AS (
SELECT
az.product_id,
dts.tag_pair_binary AS facility_level_tag_pair,
ftp.facility_tag_pair AS sku_level_tag_pair,
dts.priority,
case when az.inventory_id = 33 then 16
when az.inventory_id = 37 then 7
else az.inventory_id
end as inventory_id,
az.storage_type,
dts.dc_name,
case when dts.dc_id = 33 then 16
when dts.dc_id = 37 then 7
else dc_id
end as dc_id,
dts.review_1_date,
dts.review_2_date,
dts.order_date,
dts.pickup_date,
dts.delivery_date
FROM
availability_zero az
LEFT JOIN
dc_transfer_schedule dts
ON CASE
WHEN az.inventory_id = 33 THEN 16
WHEN az.inventory_id = 37 THEN 7
ELSE az.inventory_id
END = CASE
WHEN dts.fc_id = 33 THEN 16
WHEN dts.fc_id = 37 THEN 7
ELSE dts.fc_id
END
AND (
(az.storage_type = 'F' AND dts.storage_type = 'Frozen') OR
(az.storage_type = 'N' AND dts.storage_type = 'Dry') OR
(az.storage_type = 'R' AND dts.storage_type = 'Fresh')
)
LEFT JOIN sandbox.facility_tag_pair_sku ftp
ON az.product_id = ftp.product_id AND dts.tag_pair = ftp.facility_tag_pair
),
