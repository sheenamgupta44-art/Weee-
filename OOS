DROP TABLE IF EXISTS last_available_input;
CREATE TEMPORARY TABLE last_available_input AS (
WITH
fallback_last_available AS (
SELECT
iv.product_id,
iv.warehouse_number AS inventory_id,
MAX(iv.record_date) AS fallback_visit_day
FROM
 sc_inventory_version iv
JOIN
dc_sku_transfer_schedule sku
ON iv.product_id = sku.product_id
AND iv.warehouse_number = sku.priority_1_dc_id
WHERE
iv.available_qty > 0
AND iv.record_date < sku.priority_1_dc_order_date -- Pre-filter here
GROUP BY
iv.product_id, iv.warehouse_number
),
last_available_data AS (
SELECT
sku.priority_1_dc_id AS inventory_id,
sku.product_id,
COALESCE(
MAX(a.visit_day),
MAX(fba.fallback_visit_day)
) AS last_available_date,
MAX(sku.priority_1_dc_order_date) AS priority_1_dc_order_date,
MAX(a.product_sale_status_title) AS product_sale_status_title,
MAX(a.weee_buyer_name) as weee_buyer_name,
MAX(irs.target_quantity) AS target_quantity,
MAX(irs.sellable_quantity) AS sellable_quantity,
MAX(irs.order_quantity) AS order_quantity,
MAX(irs.avg_daily_sales) AS avg_daily_sales,
MAX(irs.avg_daily_demand_forecast) AS avg_daily_demand_forecast
FROM
dc_sku_transfer_schedule sku
LEFT JOIN
fallback_last_available fba
ON sku.product_id = fba.product_id AND sku.priority_1_dc_id = fba.inventory_id
LEFT JOIN
metrics.product_availability a
ON sku.product_id = a.product_id AND sku.priority_1_dc_id = a.inventory_id
LEFT JOIN
dwd.irs_network_product_calculation irs
ON sku.product_id = irs.product_id AND sku.priority_1_dc_id = irs.facility_id AND a.visit_day = irs.snapshot_date
WHERE
COALESCE(a.visit_day, fba.fallback_visit_day) IS NOT NULL
GROUP BY
sku.priority_1_dc_id,
sku.product_id
)
SELECT *
FROM last_available_data
);

