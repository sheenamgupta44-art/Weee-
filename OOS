DROP TABLE IF EXISTS fcst_sales;
CREATE TEMPORARY TABLE fcst_sales AS (
SELECT
im.inventory_id,
im.product_id,
irs.order_quantity,
irs.sellable_quantity,
irs.target_quantity,
max(bd.promo_lift_qty) as promo_lift_qty,
MIN(bd.rec_create_time) AS earliest_inputted_demand_date,
CASE
when min(bs.sold_qty) is not null then min(bs.sold_qty)
--WHEN MIN(irs.avg_daily_sales) IS NULL THEN MIN(bs.sold_qty)
ELSE MIN(irs.avg_daily_sales)
END AS avg_daily_sales,
CASE
--when min(fwdf.qty_demand_forecasted) is not null then min(fwdf.qty_demand_forecasted)
when min(laf.qty_forecasted) is not null then min(laf.qty_forecasted)
WHEN MIN(irs.avg_daily_demand_forecast) IS NULL THEN MIN(bd.df_qty)
ELSE MIN(irs.avg_daily_demand_forecast)
END AS avg_daily_demand_forecast
FROM input_metrics im
left join available_date_adjusted_df laf on laf.product_id = im.product_id and laf.inventory_id = im.inventory_id
LEFT JOIN last_available_input la ON
im.product_id = la.product_id AND im.inventory_id = la.inventory_id
--left join four_week_df fwdf on im.product_id = fwdf.product_id and im.inventory_id = fwdf.inventory_id
LEFT JOIN   irs_network_product_calculation irs ON
im.product_id = irs.product_id AND im.inventory_id = irs.facility_id AND irs.snapshot_date = la.last_available_date
LEFT JOIN backup_demand bd ON
im.product_id = bd.product_id AND im.inventory_id = bd.inventory_id
LEFT JOIN backup_sales bs ON
im.product_id = bs.product_id AND im.inventory_id = bs.inventory_id
GROUP BY im.product_id, im.inventory_id,irs.order_quantity,irs.sellable_quantity,irs.target_quantity
);

