else b.order_cycle end
)-6), ',', NS.n)) :: int AS order_week
, b.lead_time
, c.week_begin_date + b.order_weekday as order_date
, c.week_begin_date + b.order_weekday + b.lead_time as delivery_date
from NS
inner join
(select
