DROP TABLE IF EXISTS available_date_adjusted_df;
CREATE TEMPORARY TABLE available_date_adjusted_df AS (
select df.product_id,ism.warehouse_number as inventory_id,
min(df.sales_org_id) as sales_org_id,
min(im.order_date) as order_date,
min(im.last_available_date) as last_available_date,
min(df.snapshot_date) as snapshot_date,
min(df.day) as date_demand_forecasted_for,
min(df.qty_final) as qty_forecasted
from dwd.df_demand_forecast_daily_snapshot63 df inner join
  wms_inv_sales_mapping ism on df.sales_org_id = ism.sales_org_id
inner join input_metrics im on
im.product_id = df.product_id and im.inventory_id = ism.warehouse_number and im.last_available_date = df.day
WHERE
--getting forecast at time of order_date for last_available_date at a daily level when order_date is before last_available_date
(
im.order_date < im.last_available_date
AND df.snapshot_date - order_date <= 7 and df.snapshot_date - order_date > 0
)
OR
--getting four week forecast for last_available_date when last_available_date is before most recent order_date
(
last_available_date < im.order_date
AND (last_available_date - df.snapshot_date > 28 and last_available_date - df.snapshot_date < 35))
group by 1,2
);

