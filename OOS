WHEN priority = 3 AND facility_level_tag_pair = 0 THEN review_2_date
WHEN priority = 3 AND facility_level_tag_pair = 1 AND sku_level_tag_pair IS NOT NULL THEN review_2_date
WHEN priority = 4 AND facility_level_tag_pair = 0 THEN review_2_date
WHEN priority = 4 AND facility_level_tag_pair = 1 AND sku_level_tag_pair IS NOT NULL THEN review_2_date
ELSE NULL -- Adding a default NULL case to ensure we filter unwanted rows
END AS priority_1_dc_review_date_2,
CASE
WHEN priority = 1 AND facility_level_tag_pair = 0 THEN order_date
WHEN priority = 1 AND facility_level_tag_pair = 1 AND sku_level_tag_pair IS NOT NULL THEN order_date
WHEN priority = 2 AND facility_level_tag_pair = 0 THEN order_date
