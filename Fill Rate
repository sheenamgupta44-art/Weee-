DROP TABLE IF EXISTS sandbox.fillrate_weighted;

CREATE TABLE sandbox.fillrate_weighted AS (

WITH problem_po AS (
    SELECT po_number
    FROM dwd.user_bpm_po_receipt
    WHERE ticket_type IN (4,5,6,7,9,12)
    GROUP BY 1
), 

first_version_dtm AS (
    SELECT purchase_order_id, MIN(rec_update_time) AS first_version_dtm
    FROM dwd.sc_purchase_order_line_snapshot pols
    WHERE pols.sign = 'F'
    GROUP BY 1
), 

vendor_portal_po AS (
    SELECT purchase_order_id
    FROM dwd.sc_po_proposal pp
    WHERE status != 'X'
    GROUP BY 1
), 

vendor_portal_response AS (
    SELECT 
        pp.id AS proposal_id,
        pp.purchase_order_id,
        pp.offer_user_id,
        pp.version,
        pp.rec_update_time,
        CASE WHEN pp.offer_user_id IS NOT NULL THEN 1 ELSE 0 END AS vendor_replied,
        ROW_NUMBER() OVER (
            PARTITION BY pp.purchase_order_id 
            ORDER BY vendor_replied DESC, pp.rec_update_time
        ) AS respond_seq
    FROM dwd.sc_po_proposal pp
    WHERE status != 'X'
), 

po_line_base AS (
    SELECT *, ROW_NUMBER() OVER (
        PARTITION BY purchase_order_id, product_id 
        ORDER BY purchase_order_line_id ASC
    ) AS rn
    FROM dws.sc_purchase_order_product
),

po_line_selected AS (
    SELECT * FROM po_line_base WHERE rn = 1
),

sop_deduped AS (
    SELECT *, ROW_NUMBER() OVER (
        PARTITION BY purchase_order_id, product_id 
        ORDER BY purchase_order_line_id DESC
    ) AS rn
    FROM dws.sc_purchase_order_product
),

output1 AS (
    SELECT 
        s.est_delivery_week,
        s.est_delivery_date,
        s.po_issue_date,
        s.inventory_id,
        s.inventory_title,
        s.inventory_id || ' - ' || s.inventory_title AS inventory,
        s.delivery_inventory_id || ' - ' || s.delivery_inventory_title AS connecting_warehouse,
        s.third_inventory_id || ' - ' || s.third_inventory_title AS third_party_warehouse,
        s.vendor_id,
        s.vendor_id || ' - ' || s.vendor_title AS vendor,
        s.purchase_order_id,
        s.product_id,
        mp.short_title_en,
        mp.short_title_zh,
        mp.sku_owner,
        mp.division_id || ' - ' || mp.division AS division,
        mp.department_num || ' - ' || mp.department AS department,
        mp.category_num || ' - ' || mp.category AS category,
        mp.product_ethnicity,
        mp.storage_type,
        mp.is_imported AS import_flag,
        mptui.tier,
        CASE WHEN dc.dc_flag IS NULL THEN 'N' ELSE dc.dc_flag END AS dc_flag,
        s.receipt_date,
        s.po_status,
        s.po_status_desc,
        s.po_type,
        s.sent_to_vendor,
        CASE WHEN s.is_transfer = 1 THEN 'X-Dock' ELSE 'Vendor_delivery' END AS delivery_method,
        NVL(s.receipt_quantity,0)/s.quantity_per_unit * 1.0 AS received_quantity_cs, 
        NVL(s.receipt_quantity,0) * 1.0 AS received_quantity_unit,
        NVL(pls.original_quantity,0) * 1.0 AS original_ordered_quantity_cs,
        NVL(pls.original_quantity,0) * 1.0 * s.quantity_per_unit AS original_ordered_quantity_unit,
        NVL(s.purchase_product_quantity,0) * 1.0 AS final_ordered_quantity_cs,
        NVL(s.purchase_product_quantity,0) * 1.0 * s.quantity_per_unit AS final_ordered_quantity_unit,
        NVL(s.purchase_gift_quantity,0) * 1.0 * s.quantity_per_unit AS final_ordered_gift_quantity_unit,
        NVL(s.putaway_quantity,0) * 1.0 AS putaway_quantity_unit,
        CASE WHEN DATEDIFF('day', s.est_delivery_date, s.receipt_date) BETWEEN -3 AND 1 THEN 'Y' ELSE 'N' END AS on_time_flag,
        CASE WHEN p.po_number IS NOT NULL THEN 'Y' ELSE 'N' END AS problem_po_flag,
        CONVERT_TIMEZONE('UTC', so.timezone, fvd.first_version_dtm) AS first_version_po_issue_dtm,
        CASE WHEN vpp.purchase_order_id IS NOT NULL THEN 'Y' ELSE 'N' END AS vendor_portal_po_flag,
        CONVERT_TIMEZONE('UTC', so.timezone, vpr.rec_update_time) AS vendor_portal_respond_dtm,
        CASE 
            WHEN DATEDIFF('day', 
                          CONVERT_TIMEZONE('UTC', so.timezone, fvd.first_version_dtm)::DATE, 
                          CONVERT_TIMEZONE('UTC', so.timezone, vpr.rec_update_time)::DATE) <= 2 
            THEN 'Y'
            ELSE 'N'
        END AS vendor_portal_respond_on_time_flag
    FROM sop_deduped s
    LEFT JOIN dim.inventory i ON i.inventory_id = s.inventory_id
    LEFT JOIN dim.sales_org so ON so.sales_org_id = i.sales_org_id
    LEFT JOIN problem_po p ON p.po_number = s.purchase_order_id
    LEFT JOIN first_version_dtm fvd ON fvd.purchase_order_id = s.purchase_order_id
    LEFT JOIN vendor_portal_po vpp ON vpp.purchase_order_id = s.purchase_order_id
    LEFT JOIN vendor_portal_response vpr ON vpr.purchase_order_id = s.purchase_order_id 
        AND vpr.vendor_replied = 1 
        AND vpr.respond_seq = 1
    LEFT JOIN dwd.mdse_product mp ON mp.product_id = s.product_id
    LEFT JOIN dwd.mdse_product_tier_u_inv mptui ON mptui.inventory_id = s.inventory_id 
        AND mptui.product_id = s.product_id
    LEFT JOIN (
        SELECT fc_inventory_id AS inventory_id, product_id, dc_flag
        FROM dws.sc_master_dc_sku
        UNION
        SELECT dc_inventory_id AS inventory_id, product_id, dc_flag
        FROM dws.sc_master_dc_sku
    ) dc ON dc.inventory_id = s.inventory_id AND dc.product_id = s.product_id
    LEFT JOIN po_line_selected pls ON s.purchase_order_id = pls.purchase_order_id AND s.product_id = pls.product_id
    WHERE s.rn = 1
      AND s.po_status != 'X'
      AND s.product_id <= 150000
      AND s.est_delivery_date >= '2023-07-01'
),

pa_agg AS (
    SELECT 
        product_id,
        inventory_id,
        visit_day,
        SUM(order_cnt_adjusted) AS total_weight
    FROM metrics.product_availability
    GROUP BY product_id, inventory_id, visit_day
),

pa_ranked AS (
    SELECT 
        o.product_id,
        o.inventory_id,
        o.est_delivery_date,
        pa.visit_day,
        pa.total_weight AS weight,
        ROW_NUMBER() OVER (
            PARTITION BY o.product_id, o.inventory_id, o.est_delivery_date
            ORDER BY ABS(DATEDIFF('day', pa.visit_day, o.est_delivery_date)) ASC
        ) AS rn
    FROM output1 o
    LEFT JOIN pa_agg pa ON pa.product_id = o.product_id AND pa.inventory_id = o.inventory_id
)

SELECT 
    o.*,
    pr.visit_day AS matched_visit_day,
    COALESCE(pr.weight, 1.0) AS availability_weight,

    CASE 
        WHEN o.received_quantity_unit < o.original_ordered_quantity_unit 
        THEN o.received_quantity_unit 
        ELSE o.original_ordered_quantity_unit 
    END AS unweighted_numerator,

    CASE 
        WHEN o.received_quantity_unit < o.original_ordered_quantity_unit 
        THEN o.received_quantity_unit 
        ELSE o.original_ordered_quantity_unit 
    END * COALESCE(pr.weight, 1.0) AS weighted_numerator,

    o.original_ordered_quantity_unit * COALESCE(pr.weight, 1.0) AS weighted_denominator

FROM output1 o
LEFT JOIN (
    SELECT * FROM pa_ranked WHERE rn = 1
) pr
ON o.product_id = pr.product_id
AND o.inventory_id = pr.inventory_id
AND o.est_delivery_date = pr.est_delivery_date

);
